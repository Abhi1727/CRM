def generate_theme_css(colors):
    """Generate CSS content for theme"""
    return f"""
/* Generated Theme CSS */

:root {{
    --sidebar-primary: {colors['sidebar_primary']};
    --sidebar-secondary: {colors['sidebar_secondary']};
    --header-primary: {colors['header_primary']};
    --header-secondary: {colors['header_secondary']};
    --content-bg: {colors['content_bg']};
    --content-border: {colors['content_border']};
    --text-primary: {colors['text_primary']};
    --text-secondary: {colors['text_secondary']};
    --button-primary: {colors['button_primary']};
    --button-secondary: {colors['button_secondary']};
}}

/* Sidebar Styles */
.sidebar {{
    background: linear-gradient(180deg, var(--sidebar-primary) 0%, var(--sidebar-secondary) 100%) !important;
}}

.sidebar-header {{
    background: rgba(255, 255, 255, 0.1) !important;
}}

/* Header Styles */
.top-bar {{
    background: linear-gradient(90deg, var(--header-primary) 0%, var(--header-secondary) 100%) !important;
}}

/* Content Area */
.content {{
    background: var(--content-bg) !important;
}}

/* Button Styles */
.btn-primary {{
    background: linear-gradient(135deg, var(--button-primary) 0%, var(--button-secondary) 100%) !important;
    border: none !important;
}}

/* Text Colors */
body, .text-primary {{
    color: var(--text-primary) !important;
}}

.text-secondary {{
    color: var(--text-secondary) !important;
}}

/* Border Colors */
.table td, .card {{
    border-color: var(--content-border) !important;
    border-style: solid !important;
    border-width: 1px !important;
}}
"""

# Additional functions that were in original file
@login_required
@hierarchy_required
def assign_lead(request):
    """Assign leads to team members following hierarchy rules"""
    if request.method == 'POST':
        lead_id = request.POST.get('lead_id')
        assigned_user_id = request.POST.get('assigned_user_id')
        
        if lead_id and assigned_user_id:
            from dashboard.models import Lead
            lead = get_object_or_404(Lead, id_lead=lead_id)
            assigned_user = get_object_or_404(User, id=assigned_user_id)
            
            # Check if user can assign this lead
            if lead.can_be_assigned_by(request.user):
                try:
                    lead.assign_to_user(assigned_user, request.user)
                    messages.success(request, f'Lead "{lead.name}" has been assigned to {assigned_user.get_full_name() or assigned_user.username}.')
                except PermissionError as e:
                    messages.error(request, str(e))
            else:
                messages.error(request, 'You do not have permission to assign this lead.')
        else:
            messages.error(request, 'Please select both a lead and a user.')
    
    # Get leads and users for dropdowns
    from dashboard.models import Lead
    leads = request.hierarchy_context['accessible_leads'].filter(assigned_user__isnull=True)
    users = request.hierarchy_context['accessible_users'].filter(is_active=True)
    
    context = {
        'leads': leads,
        'users': users,
        'page_title': 'Assign Lead',
    }
    return render(request, 'accounts/assign_lead.html', context)

@login_required
@hierarchy_required
def get_users_by_role(request):
    """AJAX endpoint to get users filtered by role"""
    role = request.GET.get('role', '')
    
    users = request.hierarchy_context['accessible_users']
    if role:
        users = users.filter(role=role)
    
    user_data = []
    for user in users:
        user_data.append({
            'id': user.id,
            'name': user.get_full_name() or user.username,
            'username': user.username,
            'role': user.get_role_display(),
        })
    
    return JsonResponse({'users': user_data})

@login_required
@hierarchy_required
def bulk_assign_leads(request):
    """Bulk assign multiple leads to team members"""
    if request.method == 'POST':
        lead_ids = request.POST.getlist('lead_ids')
        assigned_user_id = request.POST.get('assigned_user_id')
        
        if lead_ids and assigned_user_id:
            from dashboard.models import Lead
            assigned_user = get_object_or_404(User, id=assigned_user_id)
            leads = Lead.objects.filter(id_lead__in=lead_ids)
            
            success_count = 0
            error_count = 0
            
            for lead in leads:
                if lead.can_be_assigned_by(request.user):
                    try:
                        lead.assign_to_user(assigned_user, request.user)
                        success_count += 1
                    except PermissionError:
                        error_count += 1
                else:
                    error_count += 1
            
            if success_count > 0:
                messages.success(request, f'{success_count} leads have been assigned successfully.')
            if error_count > 0:
                messages.error(request, f'{error_count} leads could not be assigned due to permission restrictions.')
        else:
            messages.error(request, 'Please select leads and a user to assign them to.')
    
    # Get leads and users for form
    from dashboard.models import Lead
    leads = request.hierarchy_context['accessible_leads'].filter(assigned_user__isnull=True)
    users = request.hierarchy_context['accessible_users'].filter(is_active=True)
    
    context = {
        'leads': leads,
        'users': users,
        'page_title': 'Bulk Assign Leads',
    }
    return render(request, 'accounts/bulk_assign_leads.html', context)

@login_required
@hierarchy_required
def lead_transfer_history(request):
    """View lead transfer history"""
    from dashboard.models import LeadHistory
    
    # Get transfer history for accessible leads
    history = LeadHistory.objects.filter(
        lead__in=request.hierarchy_context['accessible_leads']
    ).filter(
        action__in=['assignment', 'transfer']
    ).select_related('lead', 'user').order_by('-created_at')
    
    context = {
        'history': history,
        'page_title': 'Lead Transfer History',
    }
    return render(request, 'accounts/lead_transfer_history.html', context)

@login_required
@hierarchy_required
def user_performance(request):
    """Show user performance metrics based on hierarchy"""
    from dashboard.models import Lead
    from django.db.models import Count, Q
    
    # Get users for whom to show performance
    users = request.hierarchy_context['accessible_users']
    
    performance_data = []
    for user in users:
        leads = request.hierarchy_context['accessible_leads'].filter(assigned_user=user)
        
        performance = {
            'user': user,
            'total_leads': leads.count(),
            'sale_done': leads.filter(status='sale_done').count(),
            'interested_follow_up': leads.filter(status='interested_follow_up').count(),
            'not_interested': leads.filter(status='not_interested').count(),
            'conversion_rate': 0,
        }
        
        if performance['total_leads'] > 0:
            performance['conversion_rate'] = round((performance['sale_done'] / performance['total_leads']) * 100, 2)
        
        performance_data.append(performance)
    
    context = {
        'performance_data': performance_data,
        'page_title': 'User Performance',
    }
    return render(request, 'accounts/user_performance.html', context)

@login_required
@hierarchy_required
def team_hierarchy(request):
    """Show complete team hierarchy"""
    # Get all users in the company
    company_users = User.objects.filter(company_id=request.user.company_id)
    
    # Build hierarchy structure
    hierarchy_data = []
    
    # Add owner
    owners = company_users.filter(role='owner')
    if owners.exists():
        owner = owners.first()
        hierarchy_data.append({
            'user': owner,
            'agents': []
        })
        
        # Add managers under owner
        managers = company_users.filter(manager=owner)
        for manager in managers:
            manager_data = {
                'user': manager,
                'agents': []
            }
            
            # Add team leads under manager
            team_leads = company_users.filter(team_lead=manager)
            for team_lead in team_leads:
                team_lead_data = {
                    'user': team_lead,
                    'agents': []
                }
                
                # Add agents under team lead
                agents = company_users.filter(team_lead=team_lead)
                team_lead_data['agents'] = list(agents)
                
                manager_data['agents'].append(team_lead_data)
            
            # Add direct agents under manager
            direct_agents = company_users.filter(manager=manager, team_lead__isnull=True)
            manager_data['agents'].extend(list(direct_agents))
            
            hierarchy_data[0]['agents'].append(manager_data)
    
    context = {
        'hierarchy_data': hierarchy_data,
        'current_user': request.user,
        'page_title': 'Team Hierarchy',
    }
    return render(request, 'accounts/team_hierarchy.html', context)
    
    # Define color schemes
    color_schemes = {
        'midnight': {
            'sidebar_primary': '#1a1d29',
            'sidebar_secondary': '#2d3142',
            'header_primary': '#2d3142',
